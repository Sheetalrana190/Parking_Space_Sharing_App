{
  "name": "parking_space_mobile_app_tdd",
  "version": "1.0.0",
  "description": "This is a prototype mobile app built using React Native (Expo) with a Test-Driven Development (TDD) approach.",
  "main": "index.js",
  "private": true,
  "scripts": {
  "start": "cross-env EXPO_NO_TYPESCRIPT_SETUP=1 expo start",
  "android": "cross-env EXPO_NO_TYPESCRIPT_SETUP=1 expo start --android",
  "ios": "cross-env EXPO_NO_TYPESCRIPT_SETUP=1 expo start --ios",
  "web": "cross-env EXPO_NO_TYPESCRIPT_SETUP=1 expo start --web",
  "test": "jest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "expo": "~49.0.23",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.10",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-reanimated": "~3.3.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~3.22.0",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/webpack-config": "^19.0.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^9.5.2",
    "jest": "^29.7.0",
    "jest-expo": "^49.0.0",
    "react-test-renderer": "18.2.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest/setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native|react-native|@react-navigation|expo(nent)?|@expo(nent)?/.*|expo-.*|@expo/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg))"
    ]
  }
}
